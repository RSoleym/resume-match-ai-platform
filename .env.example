SECRET_KEY=change-me

# Supabase core
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_AUTH_REDIRECT_URL=http://127.0.0.1:5000/auth/callback
SUPABASE_RESUMES_BUCKET=resumes
SUPABASE_ACTIVE_PREFIX=active
SUPABASE_ARCHIVE_PREFIX=archive

# App behavior
MAX_RESUMES=1

# Premium / optional
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PREMIUM_ACCESS_CODE=
PREMIUM_ADMIN_CODE=

# Cloudflare Pages notes
# Put sensitive values like OPENAI_API_KEY, SUPABASE_SECRET_KEY,
# PREMIUM_ACCESS_CODE, and PREMIUM_ADMIN_CODE into Cloudflare secrets,
# not into the frontend code.
